{
  "openapi": "3.0.0",
  "info": {
    "version": "2020-08-07",
    "x-release": "v4",
    "title": "Amazon Lex Runtime V2",
    "description": "<p/>",
    "x-logo": {
      "url": "https://api.apis.guru/v2/cache/logo/https_twitter.com_awscloud_profile_image.png",
      "backgroundColor": "#FFFFFF"
    },
